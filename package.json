{
  "name": "azure-devops-extension-mock",
  "version": "1.0.0",
  "description": "Jest mock for the Azure DevOps Extension SDK and REST API clients — no live Azure DevOps instance required.",
  "main": "dist/azure-devops-extension-api/index.js",
  "types": "dist/azure-devops-extension-api/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/azure-devops-extension-api/index.d.ts",
      "require": "./dist/azure-devops-extension-api/index.js",
      "default": "./dist/azure-devops-extension-api/index.js"
    },
    "./sdk": {
      "types": "./dist/azure-devops-extension-sdk/index.d.ts",
      "require": "./dist/azure-devops-extension-sdk/index.js",
      "default": "./dist/azure-devops-extension-sdk/index.js"
    },
    "./jest-helpers/amd-transformer": "./jest-helpers/amd-transformer.js",
    "./jest-helpers/setup-globals": "./jest-helpers/setup-globals.js"
  },
  "files": [
    "dist",
    "jest-helpers",
    "license",
    "readme.md"
  ],
  "type": "commonjs",
  "scripts": {
    "build": "tsc --outDir dist",
    "test": "jest --verbose",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "prepublishOnly": "npm run build && npm test && npm run audit:prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aminueza/azure-devops-extension-mock.git"
  },
  "keywords": [
    "azure-devops",
    "azure-devops-extension-api",
    "azure-devops-extension-sdk",
    "jest",
    "mock",
    "testing"
  ],
  "author": "Amanda Souza <amanda@amandasouza.app>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aminueza/azure-devops-extension-mock/issues"
  },
  "homepage": "https://github.com/aminueza/azure-devops-extension-mock#readme",
  "dependencies": {
    "@faker-js/faker": "^9.0.0"
  },
  "peerDependencies": {
    "azure-devops-extension-api": "^4.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "jest": "^29.0.0 || ^30.0.0"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "azure-devops-extension-api": "^5.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.0"
  }
}
